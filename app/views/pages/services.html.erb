<% content_for :title, "サービス" %>

<% content_for :head do %>
<style>
.page-hero {
  padding: 90px 0 80px;
  background:
    radial-gradient(50% 50% at 80% 20%, #eef3fa 0%, transparent 60%),
    radial-gradient(40% 40% at 20% 90%, #f3ebec 0%, transparent 60%),
    var(--bg);
}
.page-hero .breadcrumb { display: flex; gap: 8px; align-items: center; font-family: var(--font-en); font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-3); margin-bottom: 28px; }
.page-hero h1 { font-size: clamp(40px, 5vw, 64px); font-weight: 700; line-height: 1.2; letter-spacing: -0.01em; }
.page-hero .lede { margin-top: 28px; font-size: 17px; max-width: 60ch; }
.svc-index { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 60px; padding-top: 32px; border-top: 1px solid var(--line-2); }
.svc-index a { display: flex; flex-direction: column; gap: 6px; padding: 18px 20px; border-radius: var(--radius); border: 1px solid var(--line-2); background: rgba(255,255,255,0.6); transition: all .2s ease; }
.svc-index a:hover { background: #fff; border-color: var(--line); }
.svc-index .num { font-family: var(--font-en); font-size: 11px; letter-spacing: 0.18em; color: var(--ink-3); }
.svc-index .nm { font-size: 16px; font-weight: 600; }
.svc-index .en { font-family: var(--font-en); font-size: 12px; color: var(--ink-3); margin-top: 2px; }

.svc-block { padding: 110px 0; border-top: 1px solid var(--line-2); }
.svc-block:first-of-type { border-top: 0; }
.svc-block .svc-grid { display: grid; grid-template-columns: 1fr 1.1fr; gap: 70px; align-items: start; }
.svc-block .num-big { font-family: var(--font-en); font-size: 13px; letter-spacing: 0.2em; color: var(--accent-ink); display: flex; align-items: center; gap: 10px; }
.svc-block .num-big .dot { background: var(--accent); }
.svc-block h2 { font-size: clamp(34px, 4vw, 52px); font-weight: 700; line-height: 1.25; margin-top: 24px; letter-spacing: -0.01em; }
.svc-block .ja-sub { font-family: var(--font-serif); font-size: 18px; color: var(--ink-3); margin-top: 14px; letter-spacing: 0.04em; }
.svc-block p.body { color: var(--ink-2); font-size: 15px; line-height: 2; margin-top: 26px; max-width: 50ch; }

.feature-list { display: flex; flex-direction: column; gap: 0; margin-top: 0; }
.feature-list .item { display: grid; grid-template-columns: 80px 1fr; gap: 24px; padding: 26px 0; border-top: 1px solid var(--line-2); }
.feature-list .item:last-child { border-bottom: 1px solid var(--line-2); }
.feature-list .item .lbl { font-family: var(--font-en); font-size: 12px; letter-spacing: 0.16em; color: var(--ink-3); padding-top: 4px; }
.feature-list .item h4 { font-size: 17px; font-weight: 600; margin-bottom: 6px; }
.feature-list .item p { font-size: 14px; color: var(--ink-2); margin: 0; line-height: 1.85; }

.svc-block.cloud { background: var(--bg); }
.svc-block.cloud .panel { background: radial-gradient(60% 60% at 80% 0%, #eef3fa 0%, transparent 60%), radial-gradient(40% 40% at 0% 100%, #f1eef7 0%, transparent 60%), #fbfaf6; border-radius: var(--radius-lg); border: 1px solid var(--line-2); padding: 40px; position: sticky; top: 96px; }

.svc-block.ai { background: var(--bg-2); }
.svc-block.ai .svc-grid { grid-template-columns: 1.1fr 1fr; }
.svc-block.ai .panel { background: radial-gradient(60% 60% at 0% 0%, #ecf4f0 0%, transparent 60%), radial-gradient(40% 40% at 100% 100%, #fbeee6 0%, transparent 60%), #fbfaf6; border-radius: var(--radius-lg); border: 1px solid var(--line-2); padding: 40px; }

.svc-block.build { background: var(--bg); }
.svc-block.build .panel { background: radial-gradient(60% 60% at 80% 0%, #f1eef7 0%, transparent 60%), radial-gradient(40% 40% at 0% 100%, #eef3fa 0%, transparent 60%), #fbfaf6; border-radius: var(--radius-lg); border: 1px solid var(--line-2); padding: 40px; }

.svc-block.consult { background: var(--bg-2); }
.svc-block.consult .svc-grid { grid-template-columns: 1.1fr 1fr; }
.svc-block.consult .panel { background: radial-gradient(60% 60% at 0% 0%, #fbeee6 0%, transparent 60%), radial-gradient(40% 40% at 100% 100%, #f1eef7 0%, transparent 60%), #fbfaf6; border-radius: var(--radius-lg); border: 1px solid var(--line-2); padding: 40px; }

.chips { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 22px; }
.chip { padding: 6px 12px; border-radius: var(--radius-pill); background: rgba(255,255,255,0.7); border: 1px solid var(--line); font-family: var(--font-en); font-size: 12px; color: var(--ink-2); letter-spacing: 0.04em; }

.viz { height: 220px; border-radius: var(--radius); position: relative; overflow: hidden; margin-bottom: 26px; }
.viz-cloud { background: linear-gradient(140deg, #eef3fa 0%, #f0e7ee 100%); border: 1px solid var(--line-2); }
.viz-ai { background: linear-gradient(140deg, #ecf4f0 0%, #f6eeda 100%); border: 1px solid var(--line-2); }
.viz-build { background: linear-gradient(140deg, #f1eef7 0%, #eef3fa 100%); border: 1px solid var(--line-2); }
.viz-consult { background: linear-gradient(140deg, #fbeee6 0%, #f1eef7 100%); border: 1px solid var(--line-2); }
.viz svg { width: 100%; height: 100%; }

.panel h3 { font-size: 14px; font-weight: 600; font-family: var(--font-en); letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-3); margin: 0 0 16px; }
.panel .stat-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0; border-top: 1px solid var(--line-2); margin-top: 24px; padding-top: 22px; }
.panel .stat-row .stat { padding-right: 16px; }
.panel .stat .v { font-family: var(--font-en); font-size: 28px; font-weight: 700; letter-spacing: -0.02em; color: var(--ink); }
.panel .stat .l { font-size: 11px; color: var(--ink-3); margin-top: 2px; letter-spacing: 0.06em; }

.pricing { background: var(--bg); padding: 110px 0; border-top: 1px solid var(--line-2); }
.pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 48px; }
.plan { border-radius: var(--radius-lg); background: #fff; border: 1px solid var(--line-2); padding: 36px 32px; display: flex; flex-direction: column; gap: 20px; }
.plan.featured { background: linear-gradient(180deg, #fbfaf6, #fff); border-color: var(--ink); box-shadow: var(--shadow); position: relative; }
.plan.featured::before { content: "Recommended"; position: absolute; top: -12px; left: 32px; font-family: var(--font-en); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; background: var(--ink); color: #fff; padding: 5px 12px; border-radius: var(--radius-pill); }
.plan h4 { font-size: 20px; font-weight: 700; }
.plan .desc { color: var(--ink-3); font-size: 13px; margin-top: -10px; line-height: 1.7; }
.plan .price { font-family: var(--font-en); font-size: 36px; font-weight: 700; letter-spacing: -0.02em; border-top: 1px solid var(--line-2); padding-top: 22px; }
.plan .price small { font-size: 14px; font-weight: 500; color: var(--ink-3); margin-left: 6px; letter-spacing: 0; }
.plan ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 11px; font-size: 14px; color: var(--ink-2); flex: 1; }
.plan ul li { padding-left: 22px; position: relative; line-height: 1.7; }
.plan ul li::before { content: ""; position: absolute; left: 0; top: 9px; width: 12px; height: 1px; background: var(--ink-4); }
.plan .cta-btn { margin-top: 8px; padding: 13px 18px; border-radius: var(--radius-pill); border: 1px solid var(--line); background: #fff; text-align: center; font-size: 14px; font-weight: 600; color: var(--ink); display: block; }
.plan.featured .cta-btn { background: var(--ink); color: #fff; border-color: var(--ink); }

.faq { padding: 110px 0; background: var(--bg-2); }
.faq-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 60px; }
.faq-item { padding: 26px 0; border-top: 1px solid var(--line); display: grid; grid-template-columns: 28px 1fr; gap: 18px; }
.faq-item:last-child { border-bottom: 1px solid var(--line); }
.faq-item .q-mark { font-family: var(--font-en); font-weight: 700; color: var(--accent-ink); font-size: 16px; }
.faq-item h4 { font-size: 17px; font-weight: 600; margin-bottom: 10px; }
.faq-item p { color: var(--ink-2); font-size: 14px; line-height: 1.9; margin: 0; }

@media (max-width: 980px) {
  .svc-block .svc-grid { grid-template-columns: 1fr; gap: 40px; }
  .svc-block.ai .svc-grid, .svc-block.consult .svc-grid { grid-template-columns: 1fr; }
  .svc-index { grid-template-columns: 1fr 1fr; }
  .pricing-grid { grid-template-columns: 1fr; }
  .faq-grid { grid-template-columns: 1fr; }
}
</style>
<% end %>

<section class="page-hero">
  <div class="container">
    <div class="breadcrumb">
      <%= link_to "Home", root_path %><span>/</span><span style="color:var(--ink);">Services</span>
    </div>
    <h1>事業に馴染む技術を、<br>4つの形でご提供します。</h1>
    <p class="lede">Lumioは「作って終わり」を作りません。クラウド・AI・受託開発・技術顧問の4領域を、お客様のフェーズに合わせて柔軟に組み合わせ、ゆるやかな前進を一緒に重ねます。</p>
    <div class="svc-index">
      <a href="#cloud"><span class="num">01</span><span class="nm">クラウド基盤構築</span><span class="en">Cloud Engineering</span></a>
      <a href="#ai"><span class="num">02</span><span class="nm">AI・データ活用</span><span class="en">AI &amp; Data</span></a>
      <a href="#build"><span class="num">03</span><span class="nm">受託開発</span><span class="en">Product Build</span></a>
      <a href="#consult"><span class="num">04</span><span class="nm">技術顧問</span><span class="en">Tech Advisory</span></a>
    </div>
  </div>
</section>

<!-- 01 CLOUD -->
<section class="svc-block cloud" id="cloud">
  <div class="container svc-grid">
    <div>
      <div class="num-big"><span class="dot"></span>01 / Cloud Engineering</div>
      <h2>クラウド基盤<br>構築・運用</h2>
      <div class="ja-sub">— 静かに、止まらない、芯のある基盤を。</div>
      <p class="body">AWS・Google Cloud・Azureを横断したアーキテクチャ設計から、Terraformによる構成管理、SREの定着、そしてコスト最適化まで。"動き続ける"ことが当たり前になる、しなやかな基盤をご提供します。</p>
      <div class="chips">
        <span class="chip">AWS</span><span class="chip">GCP</span><span class="chip">Azure</span>
        <span class="chip">Terraform</span><span class="chip">Kubernetes</span><span class="chip">Datadog</span><span class="chip">SRE</span>
      </div>
    </div>
    <div class="panel">
      <div class="viz viz-cloud">
        <svg viewBox="0 0 480 220" preserveAspectRatio="none">
          <defs><linearGradient id="g1" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#b8c6e0"/><stop offset="1" stop-color="#d8b6c4"/></linearGradient></defs>
          <g stroke="#9aa0ad" stroke-width="0.6" fill="none" opacity="0.3"><path d="M0 60 L480 60 M0 110 L480 110 M0 160 L480 160"/></g>
          <g stroke="#3f5a93" stroke-width="1.4" fill="none" opacity="0.7"><path d="M40 160 Q120 60 200 110 T360 90 T440 130"/></g>
          <g fill="url(#g1)" opacity="0.85"><circle cx="40" cy="160" r="5"/><circle cx="200" cy="110" r="5"/><circle cx="360" cy="90" r="5"/><circle cx="440" cy="130" r="5"/></g>
          <g stroke="#1f2330" stroke-width="0.8" fill="none">
            <rect x="60" y="30" width="56" height="36" rx="6" fill="#fff"/>
            <rect x="180" y="30" width="56" height="36" rx="6" fill="#fff"/>
            <rect x="300" y="30" width="56" height="36" rx="6" fill="#fff"/>
            <line x1="116" y1="48" x2="180" y2="48" stroke-dasharray="3 3"/>
            <line x1="236" y1="48" x2="300" y2="48" stroke-dasharray="3 3"/>
          </g>
          <g font-family="Plus Jakarta Sans" font-size="9" fill="#3a3f4d" letter-spacing="0.5">
            <text x="68" y="52">EDGE</text><text x="186" y="52">APP TIER</text><text x="306" y="52">DATA</text>
          </g>
        </svg>
      </div>
      <h3>What you'll get</h3>
      <div class="feature-list">
        <div class="item"><span class="lbl">A.</span><div><h4>マルチクラウド設計</h4><p>事業要件に合わせて、ベンダーロックを避けた現実的な構成を。</p></div></div>
        <div class="item"><span class="lbl">B.</span><div><h4>IaC/CI/CDの内製化</h4><p>Terraform・GitHub Actionsを軸に、運用が回り続ける土台を。</p></div></div>
        <div class="item"><span class="lbl">C.</span><div><h4>SRE運用と監視</h4><p>SLO/SLIをチームに馴染ませ、夜間運用の負荷を減らす。</p></div></div>
        <div class="item"><span class="lbl">D.</span><div><h4>コスト最適化</h4><p>未使用リソースの可視化と、予約購入・スポット活用で平均30%超を削減。</p></div></div>
      </div>
      <div class="stat-row">
        <div class="stat"><div class="v">38<span style="font-size:18px;color:var(--ink-3);">%</span></div><div class="l">平均コスト削減</div></div>
        <div class="stat"><div class="v">99.95<span style="font-size:18px;color:var(--ink-3);">%</span></div><div class="l">SLO実績</div></div>
        <div class="stat"><div class="v">42<span style="font-size:18px;color:var(--ink-3);">件</span></div><div class="l">移行支援実績</div></div>
      </div>
    </div>
  </div>
</section>

<!-- 02 AI -->
<section class="svc-block ai" id="ai">
  <div class="container svc-grid">
    <div class="panel">
      <div class="viz viz-ai">
        <svg viewBox="0 0 480 220" preserveAspectRatio="none">
          <defs><radialGradient id="g2" cx="0.5" cy="0.5" r="0.6"><stop offset="0" stop-color="#ffffff" stop-opacity="0.9"/><stop offset="1" stop-color="#b6c8a8" stop-opacity="0"/></radialGradient></defs>
          <circle cx="240" cy="110" r="80" fill="url(#g2)"/>
          <g stroke="#5a7a64" stroke-width="0.8" fill="none" opacity="0.6">
            <circle cx="240" cy="110" r="50"/><circle cx="240" cy="110" r="80"/><circle cx="240" cy="110" r="105"/>
          </g>
          <g fill="#1f2330">
            <circle cx="240" cy="110" r="3"/><circle cx="290" cy="110" r="2.2"/><circle cx="190" cy="110" r="2.2"/>
            <circle cx="240" cy="60" r="2.2"/><circle cx="240" cy="160" r="2.2"/>
            <circle cx="320" cy="110" r="2.2"/><circle cx="160" cy="110" r="2.2"/>
          </g>
          <g stroke="#1f2330" stroke-width="0.6" fill="none" opacity="0.5">
            <line x1="240" y1="110" x2="290" y2="110"/><line x1="240" y1="110" x2="190" y2="110"/>
            <line x1="240" y1="110" x2="240" y2="60"/><line x1="240" y1="110" x2="240" y2="160"/>
          </g>
        </svg>
      </div>
      <h3>What you'll get</h3>
      <div class="feature-list">
        <div class="item"><span class="lbl">A.</span><div><h4>業務適用型 生成AI</h4><p>RAGとガードレールを前提に、社内文脈に馴染む実装を。</p></div></div>
        <div class="item"><span class="lbl">B.</span><div><h4>データ基盤構築</h4><p>Snowflake/BigQuery/dbtで、意思決定に効く土台を。</p></div></div>
        <div class="item"><span class="lbl">C.</span><div><h4>機械学習PoC→本番化</h4><p>使える精度に至る道筋を、現場と検証しながら。</p></div></div>
        <div class="item"><span class="lbl">D.</span><div><h4>AIガバナンス支援</h4><p>運用ガイドライン・社内研修の整備までサポート。</p></div></div>
      </div>
      <div class="stat-row">
        <div class="stat"><div class="v">28<span style="font-size:18px;color:var(--ink-3);">件</span></div><div class="l">AI実装プロジェクト</div></div>
        <div class="stat"><div class="v">40<span style="font-size:18px;color:var(--ink-3);">%</span></div><div class="l">業務時間削減 (中央値)</div></div>
        <div class="stat"><div class="v">12<span style="font-size:18px;color:var(--ink-3);"></span></div><div class="l">専任データ人材</div></div>
      </div>
    </div>
    <div>
      <div class="num-big"><span class="dot"></span>02 / AI &amp; Data</div>
      <h2>AI・データ活用</h2>
      <div class="ja-sub">— "使われる仕組み"を、現場と一緒に。</div>
      <p class="body">生成AIの導入から、データ基盤の整備、社内データの可視化まで。技術が先行しがちなテーマだからこそ、目的と運用に立ち返り、地に足のついた実装を心がけています。PoCで終わらせない、その一歩先まで。</p>
      <div class="chips">
        <span class="chip">OpenAI / Claude</span><span class="chip">LangChain</span><span class="chip">Snowflake</span>
        <span class="chip">BigQuery</span><span class="chip">dbt</span><span class="chip">Databricks</span><span class="chip">Looker</span>
      </div>
    </div>
  </div>
</section>

<!-- 03 BUILD -->
<section class="svc-block build" id="build">
  <div class="container svc-grid">
    <div>
      <div class="num-big"><span class="dot"></span>03 / Product Build</div>
      <h2>受託開発</h2>
      <div class="ja-sub">— 引き渡したあとも、続く設計を。</div>
      <p class="body">Webアプリ・業務システム・モバイルアプリ。要件定義からデザイン、実装、テスト、運用、そして内製化まで。少人数の専任チームで、お客様の事業速度に合わせた開発をご提供します。</p>
      <div class="chips">
        <span class="chip">React / Next.js</span><span class="chip">TypeScript</span><span class="chip">Node.js</span>
        <span class="chip">Go</span><span class="chip">Python</span><span class="chip">Swift / Kotlin</span><span class="chip">Figma</span>
      </div>
    </div>
    <div class="panel">
      <div class="viz viz-build">
        <svg viewBox="0 0 480 220" preserveAspectRatio="none">
